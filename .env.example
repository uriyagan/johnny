# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Feature flags ---
# When true, the app uses src/mocks instead of live Meta/Stripe/Gemini APIs.
NEXT_PUBLIC_USE_MOCKS=true

# --- Gemini (Milestone 4+) ---
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Stripe (Milestone 6+) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (Milestone 7) ---
RESEND_API_KEY=

# --- Meta (Milestone 5+, live tokens) ---
META_APP_ID=
META_APP_SECRET=

# --- Cron (Cloudflare Worker → /api/cron/*) ---
CRON_SECRET=
